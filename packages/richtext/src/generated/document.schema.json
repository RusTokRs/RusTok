{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RichTextDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "content"],
  "properties": {
    "type": { "const": "doc" },
    "content": {
      "type": "array",
      "items": { "$ref": "#/$defs/RichTextNode" }
    }
  },
  "$defs": {
    "RichTextNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "attrs": { "type": "object" },
        "content": { "type": "array", "items": { "$ref": "#/$defs/RichTextNode" } },
        "marks": { "type": "array", "items": { "$ref": "#/$defs/RichTextMark" } },
        "text": { "type": "string" }
      }
    },
    "RichTextMark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "attrs": { "type": "object" }
      }
    }
  }
}
