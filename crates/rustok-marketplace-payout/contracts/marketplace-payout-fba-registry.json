{
  "schema_version": 1,
  "module": "marketplace_payout",
  "family": "marketplace",
  "role": "provider",
  "status": "in_progress",
  "contract_version": "marketplace.payout.v1",
  "ownership": {
    "payout_table": "marketplace_payouts",
    "item_table": "marketplace_payout_items",
    "receipt_table": "marketplace_payout_receipts",
    "operation_table": "marketplace_payout_operations",
    "operation_transfer_table": "marketplace_payout_operation_transfers",
    "cross_module_foreign_keys": false,
    "owner_internal_tenant_foreign_keys": true,
    "one_payout_per_ledger_entry": true,
    "amount_representation": "signed_64_bit_minor_units",
    "legacy_table_name_repair": "migration_owned_and_down_reversible"
  },
  "dependency": {
    "module": "marketplace_ledger",
    "read_port": "MarketplaceLedgerReadPort",
    "read_operation": "list_seller_entries",
    "reserve_operation": "post_seller_balance_transfer.reserve_hold",
    "release_operation": "post_seller_balance_transfer.reserve_release",
    "completed_receipt_replay_before_provider_read": true,
    "required_account": "seller_payable",
    "required_direction": "credit",
    "single_order_per_balance_transfer": true,
    "command_port": "MarketplaceLedgerCommandPort"
  },
  "ports": {
    "read": [
      "read_payout",
      "list_seller_payouts"
    ],
    "command": [
      "schedule_payout"
    ],
    "deadline_required": true,
    "write_idempotency_required": true
  },
  "scheduling": {
    "result_status": "scheduled",
    "max_items": 500,
    "ledger_entry_ids_semantics": "normalized_set",
    "atomic_batch": true,
    "partial_assignment_allowed": false,
    "single_seller_required": true,
    "single_currency_required": true,
    "positive_amount_required": true,
    "receipt_identity_scope": [
      "tenant_id",
      "idempotency_key"
    ],
    "request_identity": "canonical_sha256_v1",
    "lost_response_replay_returns_saved_result": true,
    "conflicting_payload": "marketplace_payout.idempotency_conflict",
    "entry_reuse": "marketplace_payout.ledger_entry_already_assigned"
  },
  "reservation_operation": {
    "source_schema_ready": true,
    "runtime_execution_ready": false,
    "typed_status_and_stage": true,
    "immutable_request_snapshot": true,
    "optimistic_revision": true,
    "lease_and_attempt_state": true,
    "safe_error_code_only": true,
    "per_order_child_operations": true,
    "deterministic_compensation_order": "reverse_sequence",
    "ledger_transfer_identity_persisted": true,
    "runtime_orchestration_implemented": true,
    "host_composition_ready": false
  },
  "execution": {
    "included_in_this_slice": false,
    "external_reference_initially_null": true,
    "paid_at_initially_null": true
  },
  "composition": {
    "modules_manifest": true,
    "distribution_feature": "mod-marketplace_payout",
    "marketplace_root_read_projection": true
  },
  "known_gaps": [
    "host command-port composition and live runtime evidence",
    "provider account and execution lifecycle",
    "verified provider webhook inbox",
    "lookup recovery",
    "ledger settlement posting",
    "external events",
    "postgres contention evidence",
    "clean and upgraded multi-backend migration evidence",
    "admin and seller surfaces"
  ]
}
