{
  "schema_version": 1,
  "module": "blog",
  "role": "consumer",
  "status": "boundary_ready",
  "consumer_profile": "blog_post_comments",
  "provider_dependencies": [
    {
      "module": "comments",
      "registry": "crates/rustok-comments/contracts/comments-fba-registry.json",
      "contract_version": "comments.thread.v1",
      "port": "CommentsThreadPort",
      "operations": [
        "create_comment",
        "get_comment",
        "list_comments_for_target",
        "list_public_comments_for_target",
        "update_comment",
        "set_comment_status",
        "delete_comment"
      ],
      "required_profiles": [
        "in_process",
        "remote_adapter_placeholder"
      ],
      "fallback_profiles": [
        "embedded_native"
      ],
      "degraded_modes": [
        "hide_comment_form",
        "show_cached_thread_snapshot"
      ],
      "context": "rustok_api::ports::PortContext",
      "error": "rustok_api::ports::PortError"
    }
  ],
  "evidence": {
    "local_plan": "crates/rustok-blog/docs/implementation-plan.md",
    "central_board": "docs/modules/registry.md",
    "verifier": "scripts/verify/verify-blog-fba.mjs",
    "static_matrix": "crates/rustok-blog/contracts/evidence/blog-comments-consumer-static-matrix.json",
    "runtime_fallback_smoke": "crates/rustok-blog/contracts/evidence/blog-comments-runtime-fallback-smoke.json",
    "consumer_runtime_order_smoke": "crates/rustok-blog/contracts/evidence/blog-comments-consumer-runtime-order-smoke.json",
    "consumer_runtime_order_smoke_runner": "scripts/verify/verify-consumer-fba-runtime-order.mjs"
  },
  "event_projection": {
    "provider": "comments",
    "events": ["comment.created", "comment.deleted"],
    "handler": "BlogCommentProjectionHandler",
    "delivery_ledger": "blog_comment_projection_deliveries",
    "publication": "BlogPostUpdated through rustok_outbox::TransactionalEventBus::publish_in_tx",
    "status": "implemented_static_only"
  },
  "contract_tests": {
    "status": "planned_cases_locked",
    "source": "crates/rustok-blog/contracts/blog-fba-registry.json",
    "runner": "scripts/verify/verify-blog-fba.mjs",
    "profiles": [
      "in_process",
      "remote_adapter_placeholder"
    ],
    "cases": [
      {
        "provider": "comments",
        "operation": "set_comment_status",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "write_idempotency_required",
          "server_richtext_view_projection",
          "server_plain_text_projection"
        ]
      },
      {
        "provider": "comments",
        "operation": "create_comment",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "write_idempotency_required",
          "typed_richtext_input",
          "server_selected_comment_profile",
          "degraded_hide_comment_form_on_unavailable"
        ]
      },
      {
        "provider": "comments",
        "operation": "list_comments_for_target",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "server_plain_text_preview",
          "degraded_cached_thread_snapshot_on_unavailable"
        ]
      },
      {
        "provider": "comments",
        "operation": "list_public_comments_for_target",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "approved_only_projection",
          "server_plain_text_preview",
          "degraded_cached_thread_snapshot_on_unavailable"
        ]
      },
      {
        "provider": "comments",
        "operation": "update_comment",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "write_idempotency_required",
          "typed_richtext_input",
          "server_selected_comment_profile"
        ]
      },
      {
        "provider": "comments",
        "operation": "delete_comment",
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "write_idempotency_required"
        ]
      }
    ],
    "fallback_smoke": {
      "status": "source_verified_no_compile",
      "profiles": [
        "embedded_native"
      ],
      "degraded_modes": [
        "hide_comment_form",
        "show_cached_thread_snapshot"
      ]
    }
  }
}
