    "profiles": [
      "in_process",
      "remote_adapter_placeholder",
      "provider_webhook_inbox"
    ],
    "cases": [
      {
        "operation": "create_or_reuse_collection",
        "profiles": [
          "in_process",
          "remote_adapter_placeholder"
        ],
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved",
          "write_idempotency_required"
        ]
      },
      {
        "operation": "read_collection_status",
        "profiles": [
          "in_process",
          "remote_adapter_placeholder"
        ],
        "assertions": [
          "typed_port_error_mapping",
          "context_deadline_preserved"
        ]
      },
      {
        "operation": "handle_webhook",
        "profiles": [
          "provider_webhook_inbox"
        ],
