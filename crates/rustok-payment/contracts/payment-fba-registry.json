    "implementation_status": "webhook_inbox_source_implemented_not_transport_verified",
    "source": "crates/rustok-payment/src/providers.rs",
    "default_provider_id": "manual",
    "operations": [
      "authorize",
      "capture",
      "cancel",
      "refund",
