{
  "schema_version": "1.0",
  "contract_id": "payment.provider_webhook.v1",
  "owner_module": "payment",
  "transport": {
    "method": "POST",
    "path": "/payment/webhooks/{provider_id}",
    "optional_identity_hint_headers": {
      "delivery_id": [
        "x-rustok-provider-delivery-id",
        "x-webhook-id",
        "idempotency-key"
      ],
      "replay_key": [
        "idempotency-key",
        "x-rustok-provider-delivery-id"
      ]
    },
    "identity_hint_policy": "untrusted-cross-check-only",
    "accepted_signature_headers": [
      "x-provider-signature",
      "stripe-signature",
      "x-webhook-signature"
    ],
    "max_raw_payload_bytes": 1048576,
    "tenant_scope_required": true
  },
  "provider_spi": {
    "registry_operation": "execute_webhook",
    "adapter_operation": "handle_webhook",
    "requirements": [
      "Verify the provider signature before returning a normalized event.",
      "Parse the raw body without mutating payment lifecycle state.",
      "Return provider_id, delivery_id, event_type, replay_key, optional external_reference, and a bounded metadata object.",
      "Derive delivery_id and replay_key from signature-verified provider data.",
      "Treat transport delivery/replay headers as optional cross-check hints only.",
      "Reject malformed, unsigned, unsupported, or hint-conflicting provider payloads with PaymentError."
    ]
  },
  "inbox": {
    "table": "payment_provider_events",
    "raw_payload_persisted": false,
    "payload_digest": "sha256-lowercase-hex",
    "identity_source": "signature-verified-provider-result",
    "deduplication_keys": [
      ["tenant_id", "provider_id", "delivery_id"],
      ["tenant_id", "provider_id", "idempotency_key"]
    ],
    "statuses": [
      "received",
      "processing",
      "failed",
      "processed",
      "dead_letter"
    ],
    "lease_required_for": ["processing"],
    "normalized_facts_atomic_with_receipt": true,
    "normalized_facts_immutable_after_receipt": true,
    "normalized_checkpoint_before_owner_apply": true,
    "checkpoint_fields": [
      "event_type",
      "external_reference",
      "event_metadata"
    ],
    "max_normalized_metadata_bytes": 65536,
    "max_normalized_metadata_depth": 16
  },
  "normalized_events": {
    "payment.authorized": {
      "external_reference_required": true,
      "metadata_required": {
        "collection_id": "uuid-string",
        "amount": "positive-decimal-string",
        "currency_code": "three-letter-code"
      }
    },
    "payment.captured": {
      "external_reference_required": true,
      "metadata_required": {
        "collection_id": "uuid-string",
        "amount": "positive-decimal-string",
        "currency_code": "three-letter-code"
      }
    },
    "payment.cancelled": {
      "external_reference_required": false,
      "metadata_required": {
        "collection_id": "uuid-string",
        "amount": "positive-decimal-string",
        "currency_code": "three-letter-code"
      }
    },
    "refund.completed": {
      "external_reference_required": true,
      "metadata_required": {
        "refund_id": "uuid-string",
        "amount": "positive-decimal-string",
        "currency_code": "three-letter-code"
      }
    },
    "chargeback.completed": {
      "external_reference_required": true,
      "metadata_required": {
        "chargeback_id": "uuid-string",
        "collection_id": "uuid-string",
        "amount": "positive-decimal-string",
        "currency_code": "three-letter-code"
      }
    }
  },
  "marketplace_reversal_extension": {
    "applicable_events": ["refund.completed", "chargeback.completed"],
    "required_when_payment_collection_contains_marketplace_lines": true,
    "metadata_path": "marketplace_reversal or metadata.marketplace_reversal",
    "fields": {
      "source_id": "uuid-string matching refund_id or chargeback_id",
      "order_id": "uuid-string",
      "occurred_at": "rfc3339",
      "currency_code": "three-letter-code",
      "currency_exponent": "integer-0-through-9",
      "lines": {
        "min_items": 1,
        "max_items": 500,
        "item": {
          "assessment_id": "uuid",
          "allocation_id": "uuid",
          "order_line_item_id": "uuid",
          "seller_id": "uuid",
          "commission_amount": "non-negative-minor-units",
          "seller_amount": "non-negative-minor-units",
          "seller_balance_bucket": "pending|available|reserved|paid"
        }
      }
    },
    "invariants": [
      "commission_amount + seller_amount is positive for every line",
      "sum of all line economics equals the normalized provider amount after exact major-to-minor conversion",
      "refund collection identity is derived from the authoritative refund owner",
      "chargeback collection identity is supplied as a normalized provider fact",
      "marketplace consumers never parse raw provider payloads"
    ]
  },
  "processed_event_observers": {
    "contract": "PaymentProviderProcessedEventObserver",
    "registry": "PaymentProviderEventObservers",
    "applier": "PaymentObservedDomainEventApplier",
    "execution_order": [
      "payment owner apply",
      "host-composed observers",
      "payment inbox processed checkpoint"
    ],
    "mounted_surfaces": [
      "webhook ingress",
      "manual recovery API",
      "scheduled recovery worker"
    ],
    "empty_registry_is_noop": true,
    "observer_failure_uses_payment_inbox_retry_classification": true,
    "cross_module_dependency_direction": "host composition only"
  },
  "delivery_semantics": {
    "provider_delivery": "at-least-once",
    "domain_apply": "effectively-once-through-inbox-owner-idempotency-and-observer-deduplication",
    "duplicate_same_payload": "return-existing",
    "same_key_different_payload": "reject",
    "retryable_owner_or_observer_failure": "failed",
    "non_retryable_owner_or_observer_failure": "dead_letter",
    "expired_processing_lease": "claimable",
    "processed_replay": "acknowledge-without-owner-or-observer-reapply",
    "retryable_recovery": "bounded_received_failed_or_expired_processing_sweep_from_normalized_checkpoint",
    "dead_letter_replay": "operator-only-dead_letter-to-processing-using-normalized-checkpoint",
    "marketplace_historical_backfill": "bounded polling of processed normalized events with independent reversal inbox deduplication"
  },
  "operator_api": {
    "read_event": {
      "method": "GET",
      "path": "/api/payment/provider-events/{event_id}",
      "permissions_any": ["payments:read", "payments:manage"]
    },
    "list_dead_letters": {
      "method": "GET",
      "path": "/api/payment/provider-events/dead-letter",
      "permissions_any": ["payments:read", "payments:manage"],
      "max_limit": 100
    },
    "run_recovery": {
      "method": "POST",
      "path": "/api/payment/provider-events/recovery/run",
      "permissions_all": ["payments:manage"],
      "max_limit": 100,
      "eligible_statuses": ["received", "failed", "expired_processing"],
      "dead_letter_claimed": false,
      "raw_payload_required": false
    },
    "replay_dead_letter": {
      "method": "POST",
      "path": "/api/payment/provider-events/{event_id}/replay",
      "permissions_all": ["payments:manage"],
      "raw_payload_required": false
    },
    "safe_projection_excludes": [
      "idempotency_key",
      "payload_hash",
      "lease_owner",
      "lease_expires_at",
      "error_message",
      "event_metadata"
    ]
  },
  "security": {
    "signature_verification_before_inbox_insert": true,
    "verified_identity_before_inbox_insert": true,
    "transport_identity_headers_authoritative": false,
    "verified_normalized_facts_written_with_inbox_insert": true,
    "raw_provider_error_exposed_to_client": false,
    "raw_payload_logged_or_persisted": false,
    "provider_signature_exposed_to_operator_api": false,
    "tenant_scope_required": true
  },
  "evidence_status": "source_only"
}
