    "forum.topic.created": {
      "family": "root",
      "source_slug": "forum",
      "source_event_identity": "topic_id",
      "source_revision": 1
    },
    "forum.mention.user_added": {
      "family": "forum_mention_contract",
      "source_slug": "forum",
      "source_event_identity": "envelope_id",
      "source_revision": "source_revision_id"
    }
  },
  "selection": {
    "default_batch_size": 32,
    "maximum_batch_size": 64,
    "stable_order": ["created_at", "id"],
    "anti_joins_receipts": true,
    "committed_pending_dispatched_failed_are_visible": true
  },
  "runtime": {
    "environment_variable": "RUSTOK_NOTIFICATIONS_OUTBOX_INTAKE_ENABLED",
    "default_enabled": false,
    "invalid_value_enabled": false,
    "requires_background_worker_host": true,
    "shared_stop_handle": true,
    "checks_between_envelopes": true
  },
  "tests": [
    "crates/rustok-notifications/tests/outbox_intake_sqlite.rs"
  ],
  "verification": {
    "source_verifier": "scripts/verify/verify-notifications-outbox-intake.mjs",
