{
  "schema_version": 3,
  "slice": "NOTIFY-03E",
  "promoted_by_slices": ["NOTIFY-03F"],
  "canonical_plan": "crates/rustok-forum/docs/implementation-plan.md",
  "owner_plan": "crates/rustok-notifications/docs/implementation-plan.md",
  "owner_worker": "crates/rustok-notifications/src/fanout_worker.rs",
  "canonical_service": "crates/rustok-notifications/src/fanout.rs",
  "server_worker": "apps/server/src/services/notification_fanout_worker.rs",
  "bootstrap": "apps/server/src/services/server_bootstrap.rs",
  "source_selection": {
    "default_batch_size": 32,
    "maximum_batch_size": 64,
    "stable_order": ["created_at", "id"],
    "claimable_states": ["pending", "due_retryable_error", "expired_processing"],
    "selection_acquires_lease": false,
    "tenant_scoped_work_item": true,
    "canonical_service_claims_each_record": true
  },
  "job_selection": {
    "default_batch_size": 32,
    "maximum_batch_size": 64,
    "default_page_size": 256,
    "maximum_page_size": 256,
    "stable_order": ["created_at", "id"],
    "claimable_states": ["pending", "due_retryable_error", "expired_leased"],
    "selection_acquires_lease": false,
    "tenant_scoped_work_item": true,
    "canonical_service_claims_each_job": true,
    "one_audience_page_per_job_per_poll": true
  },
  "durability": {
    "materialization_delegates_to_notification_fanout_service": true,
    "audience_resolution_delegates_to_notification_fanout_service": true,
    "lease_cas_preserved": true,
    "durable_retry_and_terminal_state_preserved": true,
    "creates_final_notification_rows": false,
    "creates_delivery_attempts": false
  },
  "runtime": {
    "environment_variable": "RUSTOK_NOTIFICATIONS_FANOUT_WORKER_ENABLED",
    "default_enabled": false,
    "invalid_value_enabled": false,
    "requires_background_worker_host": true,
    "requires_materialized_nonempty_source_registry": true,
    "requires_module_registry": true,
    "shared_stop_handle": true,
    "checks_between_source_records": true,
    "checks_between_fanout_jobs": true,
    "poll_interval_ms": 500
  },
  "tenant_capability_gate": {
    "authority": "EffectiveModulePolicyService::is_enabled",
    "module_slug": "notifications",
    "checked_before_each_source_claim": true,
    "checked_before_each_job_claim": true,
    "policy_error_fails_closed": true,
    "disabled_tenant_calls_provider": false,
    "direct_module_table_read_forbidden": true
  },
  "tenant_policy_backoff": {
    "owner_contract": "NotificationFanoutPolicyDeferral",
    "disabled_retry_seconds": 300,
    "policy_unavailable_retry_seconds": 30,
    "source_and_job_rows_transition_to_retryable_error": true,
    "attempt_count_incremented": true,
    "lease_fields_cleared": true,
    "stable_error_code_persisted": true,
    "cas_rejects_concurrent_claim": true,
    "prevents_disabled_tenant_head_of_line_starvation": true
  },
  "tests": [
    "crates/rustok-notifications/tests/fanout_worker_sqlite.rs",
    "crates/rustok-notifications/tests/fanout_policy_deferral_sqlite.rs"
  ],
  "verification": {
    "source_verifier": "scripts/verify/verify-notifications-fanout-worker.mjs",
    "execution_status": "not_run_by_implementation_agent"
  },
  "deferred": [
    "PostgreSQL lease contention and recovery evidence",
    "worker health, queue lag, and retry metrics",
    "default deployment enablement",
    "moderator audience expansion",
    "grouping and channel delivery"
  ]
}
