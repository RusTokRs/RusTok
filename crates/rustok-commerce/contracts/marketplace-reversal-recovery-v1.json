{
  "schema_version": 1,
  "contract_id": "commerce.marketplace_reversal_recovery.v1",
  "owner_module": "commerce",
  "status": "source_ready_unvalidated",
  "input": {
    "source": "signature-verified payment provider normalized event after payment owner apply",
    "event_types": ["refund.completed", "chargeback.completed"],
    "marketplace_extension": "marketplace_reversal or metadata.marketplace_reversal",
    "ordinary_non_marketplace_event": "ignore",
    "raw_provider_payload_consumed": false,
    "exact_major_to_minor_conversion": true
  },
  "authoritative_checks": {
    "refund": [
      "refund exists in payment owner",
      "refund status is refunded",
      "refund amount and currency match normalized provider facts",
      "payment collection is derived from refund owner",
      "refund id matches reversal source id"
    ],
    "chargeback": [
      "payment collection exists in payment owner",
      "payment collection is captured",
      "chargeback amount does not exceed captured amount",
      "provider, order, and currency identities match",
      "chargeback id matches reversal source id"
    ],
    "marketplace": [
      "line economics equal exact provider minor-unit amount",
      "root MarketplaceFinancialCommandPort validates reversal result",
      "ledger owner enforces original-entry capacity and balance"
    ]
  },
  "delivery": {
    "observer_contract": "PaymentProviderProcessedEventObserver",
    "observer_registry": "PaymentProviderEventObservers",
    "observed_applier": "PaymentObservedDomainEventApplier",
    "mounted_surfaces": [
      "payment webhook ingress",
      "payment manual recovery API",
      "payment scheduled recovery worker"
    ],
    "payment_event_processed_after_observers": true,
    "scheduled_processed_event_polling": "bounded backfill and fallback",
    "backfill_filter_by_database": {
      "postgres": "event_metadata::text",
      "sqlite": "CAST(event_metadata AS TEXT)",
      "mysql": "CAST(event_metadata AS CHAR)"
    },
    "duplicate_delivery_safe_through": [
      "payment owner idempotency",
      "marketplace reversal inbox deduplication",
      "marketplace root and ledger receipts"
    ]
  },
  "inbox": {
    "table": "marketplace_reversal_event_inbox",
    "normalized_facts_immutable": true,
    "processed_rows_immutable": true,
    "database_integrity": {
      "postgres": "checks plus immutable-fact and processed-row trigger",
      "sqlite": "insert and update triggers",
      "mysql": "insert and update triggers"
    },
    "statuses": [
      "received",
      "processing",
      "retryable_error",
      "operator_review",
      "processed"
    ],
    "deduplication_keys": [
      ["tenant_id", "provider_event_id"],
      ["tenant_id", "event_source", "event_id"],
      ["tenant_id", "reversal_kind", "source_id"]
    ],
    "processing_lease_seconds": 60,
    "stable_root_idempotency_key": "marketplace-reversal-event:{inbox_id}:v1",
    "completed_evidence": ["reversal_id", "ledger_transaction_id"]
  },
  "recovery": {
    "payment_worker": {
      "interval_seconds": 10,
      "batch_size": 50,
      "applies_host_composed_observers": true
    },
    "marketplace_worker": {
      "name": "marketplace_financial_recovery",
      "interval_seconds": 10,
      "missed_tick_behavior": "delay",
      "batch_size": 100,
      "order": [
        "adapt_historical_processed_provider_events",
        "recover_marketplace_reversal_inbox",
        "recover_marketplace_paid_event_inbox"
      ]
    },
    "eligible": ["received", "retryable_error", "expired_processing"],
    "operator_review_automatic_retry": false
  },
  "operator": {
    "permissions": {
      "read": ["payments:read"],
      "retry_and_sweep": ["payments:manage"]
    },
    "tenant_scoped": true,
    "safe_retry_requires": [
      "status is operator_review",
      "reversal_id is null",
      "ledger_transaction_id is null"
    ],
    "safe_projection_excludes": [
      "lines_json",
      "event_hash",
      "lease_owner",
      "lease_expires_at",
      "raw provider payload",
      "provider signature",
      "provider metadata"
    ],
    "rest": [
      "GET /admin/marketplace-financial/reversal-events/operator-review",
      "GET /admin/marketplace-financial/reversal-events/{id}",
      "POST /admin/marketplace-financial/reversal-events/{id}/retry",
      "POST /admin/marketplace-financial/reversal-events/recovery-sweep"
    ],
    "graphql": [
      "adminMarketplaceReversalEvent",
      "adminMarketplaceReversalEventsOperatorReview",
      "retryMarketplaceReversalEvent",
      "runMarketplaceReversalRecoverySweep"
    ],
    "openapi_registered": true
  },
  "migration": {
    "schema": "m20260721_000004_create_marketplace_reversal_event_inbox",
    "mysql_integrity": "m20260721_000005_enforce_marketplace_reversal_event_mysql_integrity",
    "dependencies": [
      "m20260721_000003_create_marketplace_paid_event_inbox",
      "m20260721_000002_add_reversals_and_seller_balances",
      "m20260714_000117_lock_provider_event_normalized_facts"
    ],
    "mysql_integrity_depends_on": "m20260721_000004_create_marketplace_reversal_event_inbox",
    "cross_module_foreign_keys": false
  },
  "validation": {
    "evidence": "not_current",
    "production_gate": "closed",
    "commands_run_for_this_slice": []
  }
}
