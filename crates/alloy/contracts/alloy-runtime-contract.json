{
  "schema_version": 1,
  "module": "alloy",
  "crate": "alloy",
  "role": "capability_runtime",
  "status": "runtime_hardening",
  "script_list_contract": {
    "status_filter": "known_script_status_or_validation_error",
    "page_min": 1,
    "per_page_min": 1,
    "per_page_max": 100,
    "ordering": [
      "name_asc",
      "id_asc"
    ],
    "pagination_order": [
      "filter",
      "sort",
      "offset",
      "limit"
    ],
    "storage_parity": [
      "sea_orm",
      "in_memory"
    ]
  },
  "execution_history_contract": {
    "routes": {
      "loco": [
        "/executions",
        "/scripts/{id}/executions"
      ],
      "axum": [
        "/executions",
        "/scripts/{id}/executions"
      ],
      "graphql": [
        "scriptExecutionHistory",
        "recentScriptExecutions",
        "scriptExecutions"
      ]
    },
    "page_min": 1,
    "per_page_min": 1,
    "per_page_max": 100,
    "ordering": "newest_first",
    "tenant_filter_before_offset": true,
    "canonical_fields": [
      "id",
      "script_id",
      "script_name",
      "phase",
      "outcome",
      "duration_ms",
      "error",
      "user_id",
      "tenant_id",
      "created_at"
    ]
  },
  "static_gates": {
    "script": "scripts/verify/verify-alloy-runtime-contract.mjs",
    "evidence": "crates/alloy/contracts/evidence/alloy-runtime-static-matrix.json"
  },
  "sandbox_contract": {
    "profiles": {
      "default": {
        "max_operations": 50000,
        "timeout_ms": 100,
        "max_call_depth": 16,
        "max_string_size": 65536,
        "max_array_size": 10000,
        "max_map_size": 16
      },
      "strict": {
        "max_operations": 10000,
        "timeout_ms": 50,
        "max_call_depth": 8
      },
      "relaxed": {
        "max_operations": 500000,
        "timeout_ms": 5000
      }
    },
    "operator_surface": "EngineConfig::limits",
    "timeout_enforcement": "post_eval_elapsed_budget_returns_timeout",
    "rhai_native_limit_mapping": [
      "ErrorTooManyOperations_to_OperationLimit",
      "ErrorDataTooLarge_to_ResourceLimit"
    ],
    "executor_timeout_observability": "warn_after_execution_budget_exceeded"
  },
  "scheduler_hook_contract": {
    "scheduler_phase": "Scheduled",
    "scheduler_tenant_context": "script_tenant_id",
    "running_flag_reset": [
      "load_error",
      "completed_success",
      "completed_aborted",
      "completed_failed"
    ],
    "hook_phases": [
      "Before",
      "After",
      "OnCommit"
    ],
    "before_outcomes": [
      "Continue",
      "Rejected",
      "Error"
    ],
    "on_commit_returns": "Vec<ExecutionResult>"
  }
}
