{
  "schema_version": 1,
  "module": "ai-alloy",
  "crate": "rustok-ai-alloy",
  "role": "domain_support_adapter",
  "status": "in_progress",
  "consumer_profile": "alloy_script_descriptor",
  "support_adapter": {
    "source": "crates/rustok-ai-alloy/src/lib.rs",
    "task_slug": "alloy_code",
    "tool_name": "direct.alloy.run_script",
    "registration_api": "register_alloy_ai_vertical_handlers",
    "validation_helper": "validate_runtime_payload",
    "execution_policy_api": "alloy_script_execution_policy",
    "runtime_operation": "run_script",
    "transport_owner": "rustok-ai"
  },
  "execution_policy": {
    "script_runtime": "alloy",
    "runtime_payload_json": "absent_blank_or_json_object",
    "sensitive": false,
    "composition_owner": "rustok-ai",
    "domain_owner": "rustok-ai-alloy",
    "remote_transport": "not_started",
    "allowed_operations": [
      "list_scripts",
      "get_script",
      "validate_script",
      "run_script"
    ]
  },
  "code_agents": {
    "owner": "rustok-ai-alloy",
    "catalog_api": "alloy_code_agents",
    "workflow_api": "alloy_swarm_workflows",
    "roles": [
      "alloy_code_planner",
      "alloy_code_implementer",
      "alloy_code_reviewer",
      "alloy_code_verifier"
    ],
    "workflow": "alloy_change_review",
    "apply_requires_approval": true,
    "stage_execution_api": "alloy_stage_execution",
    "stage_execution_bindings": [
      "alloy_code_planner:list_scripts",
      "alloy_code_implementer:validate_script",
      "alloy_code_reviewer:validate_script",
      "alloy_code_verifier:run_script"
    ]
  },
  "evidence": {
    "local_plan": "crates/rustok-ai-alloy/docs/implementation-plan.md",
    "central_registry": "docs/modules/registry.md",
    "verifier": "scripts/verify/verify-ai-alloy-policy.mjs",
    "static_matrix": "crates/rustok-ai-alloy/contracts/evidence/ai-alloy-policy-static-matrix.json"
  },
  "contract_tests": {
    "status": "source_policy_locked",
    "source": "crates/rustok-ai-alloy/contracts/ai-alloy-policy-registry.json",
    "runner": "scripts/verify/verify-ai-alloy-policy.mjs",
    "cases": [
      {
        "operation": "validate_runtime_payload",
        "assertions": [
          "blank_payload_allowed",
          "json_object_allowed",
          "json_array_rejected",
          "invalid_json_rejected"
        ]
      },
      {
        "operation": "alloy_script_execution_policy",
        "assertions": [
          "runtime_payload_shape_recorded",
          "composition_owner_stays_rustok_ai",
          "domain_owner_stays_rustok_ai_alloy",
          "remote_transport_not_started",
          "allowed_operations_recorded"
        ]
      },
      {
        "operation": "alloy_ai_vertical_descriptor",
        "assertions": [
          "task_slug_recorded",
          "tool_name_recorded",
          "runtime_operation_recorded",
          "transport_owner_stays_rustok_ai"
        ]
      },
      {
        "operation": "alloy_code_agent_catalog",
        "assertions": [
          "roles_are_owner_owned",
          "workflow_stage_order_recorded",
          "implement_and_verify_require_approval",
          "no_unreviewed_apply_operation"
        ]
      }
    ]
  }
}
