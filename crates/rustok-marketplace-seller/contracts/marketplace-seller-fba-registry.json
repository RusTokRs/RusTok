{
  "schema_version": 1,
  "module": "marketplace_seller",
  "family": "marketplace",
  "role": "provider",
  "status": "in_progress",
  "contract_version": "marketplace.seller.v1",
  "ports": [
    {
      "name": "MarketplaceSellerReadPort",
      "owner": "marketplace_seller",
      "operations": [
        "read_seller",
        "list_sellers",
        "read_membership",
        "list_members"
      ],
      "context": "rustok_api::ports::PortContext",
      "error": "rustok_api::ports::PortError",
      "idempotency_required": false,
      "deadline_required": true
    },
    {
      "name": "MarketplaceSellerCommandPort",
      "owner": "marketplace_seller",
      "operations": [
        "create_seller",
        "update_seller_profile",
        "submit_seller_onboarding",
        "review_seller_onboarding",
        "suspend_seller",
        "reactivate_seller",
        "add_seller_member",
        "update_seller_member"
      ],
      "context": "rustok_api::ports::PortContext",
      "error": "rustok_api::ports::PortError",
      "idempotency_required": true,
      "deadline_required": true,
      "durable_receipt": {
        "table": "marketplace_seller_command_receipts",
        "identity_scope": [
          "tenant_id",
          "idempotency_key"
        ],
        "request_identity": "canonical_sha256_v1",
        "request_identity_includes": [
          "command_kind",
          "actor_id",
          "effective_locale_for_localized_commands",
          "normalized_request"
        ],
        "result_snapshot": "normalized_owner_response_json",
        "atomic_with_owner_write": true,
        "conflicting_payload": "marketplace_seller.idempotency_conflict"
      }
    }
  ],
  "localized_storage": {
    "base_table": "marketplace_sellers",
    "translation_table": "marketplace_seller_translations",
    "localized_fields": [
      "display_name"
    ],
    "translation_identity": [
      "tenant_id",
      "seller_id",
      "locale"
    ],
    "locale_source": "PortContext.locale_effective",
    "locale_normalizer": "rustok_api::normalize_locale_tag",
    "locale_max_bytes": 32,
    "resolution": "exact_effective_locale",
    "resolved_locale_projection": "resolved_locale",
    "missing_translation": "marketplace_seller.translation_missing",
    "write_strategy": "transactional_on_conflict_upsert",
    "forbidden": [
      "localized_fields_in_marketplace_sellers",
      "localized_json_maps",
      "owner_invented_locale_fallback"
    ]
  },
  "consumers": [
    {
      "module": "marketplace",
      "profile": "marketplace_seller_directory",
      "degraded_modes": [
        "seller_directory_unavailable"
      ],
      "fallback_profiles": [
        "embedded_native",
        "remote_adapter_placeholder"
      ]
    },
    {
      "module": "marketplace_seller_admin",
      "profile": "marketplace_seller_admin",
      "degraded_modes": [
        "seller_directory_unavailable",
        "seller_write_retry_required"
      ],
      "fallback_profiles": [
        "embedded_native",
        "graphql_admin_compat"
      ]
    }
  ],
  "evidence": {
    "local_plan": "crates/rustok-marketplace-seller/docs/implementation-plan.md",
    "central_plan": "crates/rustok-commerce/docs/implementation-plan.md",
    "central_board": "docs/modules/registry.md",
