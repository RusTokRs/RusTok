  },
  "contract_tests": {
    "status": "planned_cases_locked",
    "profiles": [
      "in_process",
      "remote_adapter_placeholder"
    ],
    "cases": [
      {
        "operation": "read_seller",
        "assertions": [
          "tenant_scope_preserved",
          "typed_not_found",
          "context_deadline_preserved",
          "effective_locale_read_exact",
          "resolved_locale_returned",
          "missing_translation_is_invariant_violation"
        ]
      },
      {
        "operation": "list_sellers",
        "assertions": [
          "bounded_pagination",
          "tenant_scope_preserved",
          "context_deadline_preserved",
          "localized_search_uses_effective_locale_only"
        ]
      },
      {
        "operation": "list_members",
        "assertions": [
          "seller_scope_preserved",
          "tenant_scope_preserved",
          "context_deadline_preserved"
        ]
      },
      {
        "operation": "create_seller",
        "assertions": [
          "deadline_required",
          "idempotency_key_required",
          "seller_translation_and_owner_membership_atomic",
          "receipt_and_owner_write_atomic",
          "effective_locale_in_request_identity",
          "lost_response_replay_returns_saved_result",
          "conflicting_payload_rejected",
          "duplicate_handle_conflict"
        ]
      },
      {
        "operation": "update_seller_profile",
        "assertions": [
          "effective_locale_in_request_identity",
          "translation_upsert_uses_database_conflict_handling",
          "translation_update_and_receipt_atomic",
          "parallel_locales_do_not_overwrite_each_other"
        ]
      },
      {
        "operation": "review_seller_onboarding",
        "assertions": [
          "deadline_required",
          "idempotency_key_required",
          "expected_state_transition",
          "receipt_and_transition_atomic",
          "concurrent_transition_conflict"
        ]
      },
      {
        "operation": "update_seller_member",
        "assertions": [
          "seller_scope_preserved",
          "receipt_and_member_write_atomic",
          "owner_membership_cannot_be_disabled",
          "owner_membership_cannot_be_demoted"
        ]
      },
      {
        "operation": "admin_transport_parity",
        "assertions": [
          "native_and_graphql_share_command_envelope",
          "native_and_graphql_use_request_effective_locale",
          "native_and_graphql_return_resolved_locale",
          "native_and_graphql_require_same_idempotency_key",
          "selected_transport_never_implicitly_falls_back",
          "retry_reuses_original_idempotency_key"
        ]
      }
    ],
    "known_gap": "compiled migration, locale-row contention, replay contention, mounted native and GraphQL execution, and remote-profile evidence are not yet retained"
