      },
      {
        "operation": "review_seller_onboarding",
        "assertions": [
          "deadline_required",
          "idempotency_key_required",
          "expected_state_transition",
          "concurrent_transition_conflict"
        ]
      },
      {
        "operation": "update_seller_member",
        "assertions": [
          "seller_scope_preserved",
          "owner_membership_cannot_be_disabled",
          "owner_membership_cannot_be_demoted"
