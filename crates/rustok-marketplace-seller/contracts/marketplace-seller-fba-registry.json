    "translation_entity": "crates/rustok-marketplace-seller/src/entities/seller_translation.rs",
    "localized_storage": "crates/rustok-marketplace-seller/src/localized_sellers.rs",
    "receipt_entity": "crates/rustok-marketplace-seller/src/entities/seller_command_receipt.rs",
    "receipt_executor": "crates/rustok-marketplace-seller/src/command_receipts.rs",
    "receipted_commands": "crates/rustok-marketplace-seller/src/receipted_commands.rs",
    "graphql_owner_transport": "crates/rustok-marketplace-seller/src/graphql.rs",
    "native_admin_adapter": "crates/rustok-marketplace-seller/admin/src/transport/native_server_adapter.rs",
    "graphql_admin_adapter": "crates/rustok-marketplace-seller/admin/src/transport/graphql_adapter.rs",
    "admin_workflows": "crates/rustok-marketplace-seller/admin/src/ui/leptos.rs"
  },
  "in_process_provider_impl": {
    "service": "MarketplaceSellerService",
    "source": "crates/rustok-marketplace-seller/src/ports.rs",
