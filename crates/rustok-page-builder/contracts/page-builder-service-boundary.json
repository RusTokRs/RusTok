{
  "module": "page_builder",
  "domain_owner": "fly",
  "service": "FlyAdapterBackedPageBuilderService",
  "capabilities": [
    "preview",
    "tree",
    "properties",
    "publish"
  ],
  "ports": {
    "persistence": {
      "trait": "PageBuilderProjectStore",
      "methods": [
        "load_project",
        "save_project"
      ],
      "tenant_context_source": "PortContext"
    },
    "preview_rendering": {
      "trait": "PageBuilderRenderingAdapter",
      "methods": [
        "render_preview"
      ],
      "invocation_order": "after Fly decode and validation"
    },
    "runtime_telemetry": {
      "trait": "PageBuilderRuntimeTelemetry",
      "evidence": "PageBuilderRuntimeCallEvidence",
      "statuses": [
        "started",
        "succeeded",
        "failed"
      ]
    }
  },
  "guards": [
    "CapabilityGuardedService",
    "AuthorizedPageBuilderHandlers"
  ],
  "composition_root": {
    "module": "composition",
    "default_entrypoint": "compose_fly_page_builder_handlers",
    "configured_entrypoint": "compose_configured_fly_page_builder_handlers",
    "invocation_order": [
      "FlyAdapterBackedPageBuilderService::new",
      "CapabilityGuardedService::with_policies",
      "AuthorizedPageBuilderHandlers::with_authorizer"
    ]
  },
  "production_consumers": {
    "pages": {
      "source": "crates/rustok-pages/admin/src/builder.rs",
      "manifest": "crates/rustok-pages/admin/Cargo.toml",
      "server_entrypoint": "execute_publish",
      "client_entrypoint_marker": "#[cfg(not(feature = \"ssr\"))]\nasync fn execute_publish",
      "server_feature_marker": "\"rustok-page-builder/server\"",
      "tenant_ports": [
        "PagesPageBuilderProjectStore",
        "PagesPageBuilderRenderer"
      ],
      "required_server_order": [
        "leptos_auth::api::fetch_current_user",
        "PageBuilderRequestAuth::new",
        "PortContext::new",
        ".with_deadline(PAGE_BUILDER_PORT_DEADLINE)",
        ".with_idempotency_key",
        "PagesPageBuilderProjectStore {",
        "compose_fly_page_builder_handlers",
        ".handle("
      ],
      "dispatch_marker": ".handle(",
      "forbidden_before_dispatch": [
        "transport::fetch_page(",
        "transport::save_page_document(",
        "ensure_page_is_editable("
      ],
      "tenant_context_guards": [
        "fn ensure_context(&self, context: &PortContext)",
        "context.tenant_id.as_str()",
        "context.actor.id.as_str()",
        "self.ensure_context(context)?"
      ],
      "persisted_result_marker": "Arc<Mutex<Option<PublishPageBuilderResult>>>"
    }
  },
  "transport_entrypoints": [
    "handle_page_builder_graphql_endpoint",
    "handle_page_builder_leptos_server_function_endpoint"
  ],
  "forbidden_symbols": [
    "ReferencePageBuilderRenderingAdapter",
    "ReferencePageBuilderService",
    "AdapterBackedPageBuilderService",
    "FlyValidatedPageBuilderService",
    "render_preview_html",
    "extract_tree_nodes"
  ]
}
