{
  "module": "page_builder",
  "domain_owner": "fly",
  "service": "FlyAdapterBackedPageBuilderService",
  "capabilities": [
    "preview",
    "tree",
    "properties",
    "publish"
  ],
  "ports": {
    "persistence": {
      "trait": "PageBuilderProjectStore",
      "methods": [
        "load_project",
        "save_project"
      ],
      "tenant_context_source": "PortContext",
      "save_result": "PageBuilderProjectSaveResult",
      "save_result_order": [
        "let saved = match self",
        "if saved.page_id != input.page_id",
        "if saved.revision_id.trim().is_empty()",
        "record_runtime_call(&evidence.succeeded())",
        "revision_id: saved.revision_id",
        "published: saved.published"
      ]
    },
    "preview_rendering": {
      "trait": "PageBuilderRenderingAdapter",
      "methods": [
        "render_preview"
      ],
      "invocation_order": "after Fly decode and validation"
    },
    "runtime_telemetry": {
      "trait": "PageBuilderRuntimeTelemetry",
      "evidence": "PageBuilderRuntimeCallEvidence",
      "statuses": [
        "started",
        "succeeded",
        "failed"
      ]
    }
  },
  "guards": [
    "CapabilityGuardedService",
    "AuthorizedPageBuilderHandlers"
  ],
  "composition_root": {
    "module": "composition",
    "default_entrypoint": "compose_fly_page_builder_handlers",
    "configured_entrypoint": "compose_configured_fly_page_builder_handlers",
    "invocation_order": [
      "FlyAdapterBackedPageBuilderService::new",
      "CapabilityGuardedService::with_policies",
      "AuthorizedPageBuilderHandlers::with_authorizer"
    ]
  },
  "production_consumers": {
    "pages": {
      "source": "crates/rustok-pages/admin/src/builder.rs",
      "manifest": "crates/rustok-pages/admin/Cargo.toml",
      "server_entrypoint": "execute_publish",
      "client_entrypoint_marker": "#[cfg(not(feature = \"ssr\"))]\nasync fn execute_publish",
      "server_feature_marker": "\"rustok-page-builder/server\"",
      "tenant_ports": [
        "PagesPageBuilderProjectStore",
        "PagesPageBuilderRenderer"
      ],
      "required_server_order": [
        "leptos_auth::api::fetch_current_user",
        "PageBuilderRequestAuth::new",
        "PortContext::new",
        ".with_deadline(PAGE_BUILDER_PORT_DEADLINE)",
        ".with_idempotency_key",
        "PagesPageBuilderProjectStore {",
        "compose_fly_page_builder_handlers",
        ".handle("
      ],
      "dispatch_marker": ".handle(",
      "forbidden_before_dispatch": [
        "transport::fetch_page(",
        "transport::save_page_document(",
        "ensure_page_is_editable("
      ],
      "preview_server_entrypoint": "execute_preview",
      "preview_client_entrypoint_marker": "#[cfg(not(feature = \"ssr\"))]\nasync fn execute_preview",
      "preview_transport_marker": "pages_page_builder_preview(",
      "preview_required_server_order": [
        "leptos_auth::api::fetch_current_user",
        "PageBuilderRequestAuth::new",
        "PortContext::new",
        ".with_deadline(PAGE_BUILDER_PORT_DEADLINE)",
        "PagesPageBuilderRenderer {",
        "PagesPageBuilderProjectStore {",
        "compose_fly_page_builder_handlers",
        ".handle("
      ],
      "preview_dispatch_marker": ".handle(",
      "preview_forbidden_before_dispatch": [
        "transport::fetch_page(",
        "transport::save_page_document("
      ],
      "preview_renderer_context_guard": "ensure_port_context(context, &self.tenant_slug, &self.actor_id, \"renderer\")?",
      "tenant_context_guards": [
        "fn ensure_context(&self, context: &PortContext)",
        "context.tenant_id.as_str()",
        "context.actor.id.as_str()",
        "self.ensure_context(context)?",
        "transport::fetch_page(\n            Some(self.token.clone()),\n            Some(self.tenant_slug.clone()),\n            self.page_id.clone(),"
      ],
      "persisted_result_marker": "PageBuilderProjectSaveResult",
      "forbidden_symbols": [
        "Arc<Mutex<Option<PublishPageBuilderResult>>>",
        "persisted_result: Arc<Mutex",
        "Pages save state lock was poisoned"
      ],
      "admin_preview": {
        "runtime_source": "crates/rustok-page-builder/admin/src/editor/runtime.rs",
        "surface_source": "crates/rustok-page-builder/admin/src/editor/server_preview.rs",
        "host_source": "crates/rustok-page-builder/admin/src/editor/modular_canvas.rs",
        "runtime_markers": [
          "PreviewPageBuilderInput::new",
          "let active_page_index = controller.active_page_index()",
          "document.project.pages = document",
          "set(Some((project_hash, active_page_index)))",
          "PageBuilderCapabilityResponse::Preview(response)",
          "expected != (current.1, current.2)",
          "project changed while the server preview was rendering",
          "server_preview_html.set(Some(response.html))",
          "preview_in_progress.set(true)",
          "UiIntent::ActivatePage { .. }"
        ],
        "surface_markers": [
          "request_server_preview()",
          "server_preview_html.get()",
          "data-page-builder-server-preview-frame",
          "srcdoc=html"
        ],
        "host_marker": "<ServerPreviewPanel runtime=server_preview_runtime />"
      }
    }
  },
  "transport_entrypoints": [
    "handle_page_builder_graphql_endpoint",
    "handle_page_builder_leptos_server_function_endpoint"
  ],
  "forbidden_symbols": [
    "ReferencePageBuilderRenderingAdapter",
    "ReferencePageBuilderService",
    "AdapterBackedPageBuilderService",
    "FlyValidatedPageBuilderService",
    "render_preview_html",
    "extract_tree_nodes"
  ]
}
