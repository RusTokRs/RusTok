{
  "status": "boundary_ready",
  "provider": {
    "module_slug": "page_builder",
    "manifest_module": "page-builder",
    "contract": "grapesjs",
    "builder_contract_version": "1.1",
    "consumer_min_version": "1.0",
    "capabilities": ["preview", "tree", "properties", "publish"],
    "preview_runtime_contract": {
      "input": "PageBuilderPreviewRuntime",
      "port": "PageBuilderPreviewRenderingPort",
      "context_shape": "json_object",
      "context_max_bytes": 262144,
      "scenario_id_max_bytes": 128,
      "response_identity": "runtime_scenario_id"
    },
    "reviewed_publish_runtime_contract": {
      "format": "page_builder_publish_runtime_review_v1",
      "input": "PageBuilderReviewedPublishRuntime",
      "scenario_required": true,
      "review_hash_algorithm": "sha256",
      "raw_context_persisted": false
    },
    "static_sanitization_contract": {
      "format": "page_builder_static_publish_sanitization_v2",
      "function": "sanitize_static_landing_project",
      "envelope": "PageBuilderSanitizedStaticLandingProject",
      "hash_algorithm": "sha256",
      "hash_payload": ["format", "policy_format", "policy_hash", "sanitized_project"],
      "policy": {
        "format": "page_builder_static_publish_policy_v1",
        "source": "crates/rustok-page-builder/src/static_publish_policy.rs",
        "dto": "PageBuilderStaticPublishPolicy",
        "evidence": "PageBuilderStaticPublishPolicyEvidence",
        "hash_algorithm": "sha256",
        "failure_mode": "reject_not_drop",
        "domains": [
          "tags_component_types_and_markup_content",
          "attributes_and_url_schemes",
          "component_and_project_css",
          "assets_and_page_metadata_urls"
        ],
        "pre_materialization": true,
        "exact_materialized_document": true,
        "exact_materialized_recheck_source": "crates/rustok-page-builder/src/static_landing.rs"
      },
      "stable_component_ids": true,
      "secure_public_resources": true,
      "integrity_revalidates_project": true,
      "executed_evidence": "pending"
    },
    "static_materialization_contract": {
      "format": "page_builder_static_runtime_materialization_v1",
      "envelope": "PageBuilderMaterializedStaticLandingArtifact",
      "identity": "PageBuilderStaticLandingMaterializationIdentity",
      "snapshot": "RuntimeScenarioRenderSnapshot",
      "context_evidence": "runtime_context_hash",
      "scenario_evidence": "runtime_scenario_id",
      "snapshot_evidence": "runtime_snapshot_hash",
      "evidence_hash_algorithm": "sha256",
      "snapshot_document_hash_algorithm": "fly_project_hash_fnv1a64",
      "preview_static_parity": "document_html",
      "raw_context_persisted": false
    },
    "permission_map": {
      "preview": "pages:read",
      "tree": "pages:read",
      "properties": "pages:update",
      "publish": "pages:publish"
    },
    "port_call_policies": {
      "preview": "read_deadline_required",
      "tree": "read_deadline_required",
      "properties": "read_deadline_required",
      "publish": "write_deadline_and_idempotency_required"
    },
    "error_catalog": {
      "validation": "validation",
      "sanitize": "sanitize",
      "runtime": "runtime",
      "feature_disabled": "feature-disabled"
    },
    "error_codes": {"feature_disabled": "FEATURE_DISABLED"},
    "health_profile": "ready",
    "health_states": ["ready", "degraded", "unavailable"],
    "degradation_reasons": ["capability_disabled", "provider_unhealthy", "sanitize_backpressure", "publish_backlog"],
    "slo_thresholds": {
      "preview_p95_ms": 1500,
      "publish_p95_ms": 3000,
      "sanitize_failure_rate_max": 0.01,
      "runtime_error_rate_max": 0.01
    }
  },
  "consumers": [
    {
      "module_slug": "pages",
      "crate": "rustok-pages",
      "provider_module": "page-builder",
      "contract": "grapesjs",
      "contract_version": "1.1",
      "builder_contract_version": "1.1",
      "consumer_min_version": "1.0",
      "capabilities": ["preview", "tree", "properties", "publish"],
      "rollout_state": "wave0_baseline",
      "materialization_persistence": {
        "state": "integrated",
        "entity": "page_static_landing_artifact",
        "materialization_hash_column": "materialization_hash",
        "materialization_identity_column": "materialization_identity",
        "runtime_snapshots_column": "runtime_snapshots",
        "unique_key": ["tenant_id", "page_id", "locale", "build_hash", "materialization_hash"],
        "legacy_mode": "verified_static_artifact_with_null_evidence",
        "partial_evidence": "rejected",
        "storefront_integrity": "PageBuilderMaterializedStaticLandingArtifact::verify_integrity",
        "raw_context_persisted": false
      },
      "atomic_publish": {
        "state": "service_and_public_transport_integrated",
        "input": "PublishPageInput",
        "result": "PublishPageResult",
        "service": "PageService::publish_reviewed",
        "sanitizer": "sanitize_static_landing_project",
        "sanitization_format": "page_builder_static_publish_sanitization_v2",
        "policy_format": "page_builder_static_publish_policy_v1",
        "policy_hash_bound": true,
        "exact_materialized_policy_recheck": true,
        "receipt_entity": "page_publish_operation",
        "artifact_manifest_entity": "page_publish_operation_artifact",
        "artifact_manifest_identity": ["locale", "artifact_hash", "materialization_hash"],
        "artifact_manifest_persistence": "same_transaction_after_receipt_insert",
        "idempotency_unique_key": ["tenant_id", "page_id", "idempotency_key"],
        "request_identity": ["expected_version", "expected_body_revisions", "review_hash"],
        "transactional_outbox": ["NodeUpdated", "NodePublished"],
        "replay": "stored_receipt_without_rebuild_or_duplicate_events",
        "public_transport": "graphql_http_admin_reviewed_cutover",
        "scenario_selection": "explicit_ephemeral_promoted_scenario_scoped_by_page_and_baseline_hash",
        "legacy_default_publish": "removed_non_builder_lifecycle_split",
        "non_builder_publish": "publish_non_builder_if_current_rejects_grapesjs_with_PAGE_BUILDER_REVIEWED_PUBLISH_REQUIRED",
        "raw_context_persisted": false
      },
      "artifact_rollback": {
        "state": "service_public_transport_and_admin_control_integrated",
        "input": "RollbackPageInput",
        "result": "RollbackPageResult",
        "service": "PageService::rollback_to_previous",
        "selection": "latest_activation_receipt_then_older_distinct_publish_manifest",
        "history_direction": "monotonic_older_publish_result_version_only",
        "activation_cursor": {
          "source_function": "find_current_publish_cursor_in_tx",
          "publish_receipt_match": ["artifact_set_hash", "result_version_lte_current_page_version"],
          "rollback_receipt_match": ["target_artifact_set_hash", "result_version_lte_current_page_version"],
          "winner": "highest_activation_result_version",
          "rollback_resolution": "target_publish_operation_id",
          "resolved_manifest_required": true,
          "hash_match_without_activation_receipt": "rejected"
        },
        "target_manifest_required": true,
        "activation_receipt_trace_required": true,
        "receipt_entity": "page_rollback_operation",
        "idempotency_unique_key": ["tenant_id", "page_id", "idempotency_key"],
        "request_identity": ["expected_version", "target_publish_operation_id"],
        "immutable_reuse_only": true,
        "sanitize": false,
        "materialize": false,
        "compile": false,
        "transactional_outbox": ["NodeUpdated", "NodePublished"],
        "cache_invalidation": "existing_NodePublished_generation_rotation",
        "public_transport": "graphql_http_admin_control_connected",
        "admin_control": "crates/rustok-pages/admin/src/rollback_control.rs",
        "confirmation": "prepare_then_confirm_for_same_page_id",
        "browser_retry": {
          "source": "crates/rustok-pages/admin/src/transport/rollback_retry_adapter.rs",
          "storage": "session_storage_expected_version_and_idempotency_key_only",
          "network_or_5xx": "retain_same_command_identity",
          "typed_graphql_or_4xx": "clear_pending_identity"
        },
        "executed_evidence": "pending"
      },
      "cache_consumer": {
        "state": "source_connected_execution_pending",
        "owner_contract": "crates/rustok-pages/src/cache_invalidation.rs",
        "listener": "PageCacheInvalidationEventHandler",
        "invalidation_port": "PageCacheInvalidationPort",
        "read_port": "PagesCacheReadPort",
        "server_adapter": "apps/server/src/services/pages_cache_invalidation.rs",
        "server_composition": "apps/server/src/services/module_event_dispatcher.rs",
        "events": ["NodeUpdated", "NodePublished", "NodeUnpublished", "NodeDeleted"],
        "scopes": ["route", "page", "artifact"],
        "generation_store": "CacheNamespaceGenerationStore",
        "namespace_scope": "tenant_wide_per_scope",
        "variant_hash": "sha256",
        "readers": [
          "crates/rustok-pages/storefront/src/transport/native_server_adapter.rs",
          "crates/rustok-pages/src/controllers/mod.rs"
        ],
        "inline_publish_invalidation": false,
        "reader_failure_mode": "fail_open_to_owner_source_read",
        "executed_evidence": "pending"
      },
      "error_catalog": {
        "validation": "validation",
        "sanitize": "sanitize",
        "runtime": "runtime",
        "feature_disabled": "feature-disabled"
      },
      "error_codes": {
        "feature_disabled": "FEATURE_DISABLED",
        "review_invalid": "PAGE_BUILDER_PUBLISH_RUNTIME_REVIEW_INVALID",
        "sanitize_failed": "PAGE_BUILDER_PUBLISH_SANITIZE_FAILED",
        "materialization_mismatch": "PAGE_BUILDER_PUBLISH_RUNTIME_MATERIALIZATION_MISMATCH",
        "idempotency_conflict": "PAGE_PUBLISH_IDEMPOTENCY_CONFLICT",
        "receipt_integrity": "PAGE_PUBLISH_OPERATION_INTEGRITY",
        "reviewed_publish_required": "PAGE_BUILDER_REVIEWED_PUBLISH_REQUIRED",
        "rollback_idempotency_conflict": "PAGE_ROLLBACK_IDEMPOTENCY_CONFLICT",
        "rollback_receipt_integrity": "PAGE_ROLLBACK_OPERATION_INTEGRITY",
        "rollback_target_unavailable": "PAGE_ROLLBACK_TARGET_UNAVAILABLE",
        "rollback_requires_published": "PAGE_ROLLBACK_REQUIRES_PUBLISHED"
      },
      "degraded_mode_errors": {
        "builder_disabled": "FEATURE_DISABLED",
        "preview_disabled": "FEATURE_DISABLED",
        "publish_disabled": "FEATURE_DISABLED"
      }
    },
    {
      "module_slug": "forum",
      "crate": "rustok-forum",
      "provider_module": "page-builder",
      "contract": "grapesjs_v1",
      "contract_version": "1.0",
      "builder_contract_version": "1.0",
      "consumer_min_version": "1.0",
      "capabilities": ["preview", "tree", "properties", "publish"],
      "rollout_state": "deferred"
    }
  ],
  "fallback_profiles": ["all_on", "publish_off", "preview_off", "builder_off"],
  "evidence": {
    "local_plan": "crates/rustok-page-builder/docs/implementation-plan.md",
    "central_board": "docs/modules/registry.md",
    "verifier": "scripts/verify/verify-page-builder-fba-baseline.mjs",
    "reviewed_publish_verifier": "crates/rustok-page-builder/scripts/verify/verify-page-builder-publish-runtime-review.mjs",
    "publish_transport_verifier": "crates/rustok-page-builder/scripts/verify/verify-page-builder-publish-transport-cutover.mjs",
    "pages_cache_verifier": "crates/rustok-pages/scripts/verify/verify-pages-cache-invalidation.mjs",
    "pages_rollback_verifier": "crates/rustok-pages/scripts/verify/verify-pages-artifact-rollback.mjs",
    "runtime_order_smoke": "crates/rustok-page-builder/contracts/evidence/page-builder-orchestrator-runtime-order-smoke.json",
    "runtime_order_smoke_runner": "scripts/verify/verify-orchestrator-fba-runtime-order.mjs"
  }
}
