{
  "module": "page_builder",
  "contract": "grapesjs_v1",
  "adapter_seams_version": "1.0",
  "purpose": "Machine-readable contract for persistence and rendering adapters layered above the reference provider without changing capability DTOs or transport envelopes.",
  "canonical_entrypoints": [
    "PageBuilderCapabilityService",
    "AuthorizedPageBuilderHandlers::handle",
    "PageBuilderAdapterCallEvidence",
    "PageBuilderAdapterTelemetry",
    "handle_page_builder_graphql_endpoint",
    "handle_page_builder_leptos_server_function_endpoint"
  ],
  "seams": {
    "persistence": {
      "trait": "PageBuilderProjectStore",
      "methods": ["load_project", "save_project"],
      "tenant_context_source": "PortContext",
      "operation_evidence": "PageBuilderAdapterCallEvidence",
      "must_preserve": [
        "tenant isolation",
        "grapesjs_v1 schema validation",
        "PageBuilderCapabilityRequest/Response DTOs",
        "canonical transport envelopes"
      ]
    },
    "rendering": {
      "trait": "PageBuilderRenderingAdapter",
      "methods": ["render_preview"],
      "default_adapter": "ReferencePageBuilderRenderingAdapter",
      "operation_evidence": "PageBuilderAdapterCallEvidence",
      "must_preserve": [
        "sanitize errors map to PageBuilderErrorKind::Sanitize",
        "preview result remains PreviewPageBuilderResult",
        "no vendor-specific payload requirement"
      ]
    },
    "adapter_backed_service": {
      "type": "AdapterBackedPageBuilderService",
      "capabilities": ["preview", "tree", "properties", "publish"],
      "publish_policy": "host wrappers must continue to use CapabilityGuardedService for PortCallPolicy::write() enforcement",
      "default_telemetry": "NoopPageBuilderAdapterTelemetry",
      "operation_evidence_fields": [
        "module_slug",
        "contract",
        "operation",
        "tenant_id",
        "page_id",
        "revision_id",
        "correlation_id"
      ]
    }
  },
  "blocked_patterns": [
    "transport-local capability aliases",
    "transport-local error kind aliases",
    "pages-local visual builder ownership",
    "vendor-specific required project payloads"
  ],
  "docs": [
    "crates/rustok-page-builder/docs/implementation-plan.md",
    "crates/rustok-page-builder/docs/README.md",
    "docs/modules/tiptap-page-builder-implementation-plan.md"
  ]
}
