    "service": "InProcessCheckoutCompletionPort",
    "impl_type": "InProcessCheckoutCompletionPort",
    "source": "crates/rustok-order/src/ports.rs",
    "status": "source_ready_unvalidated",
    "notes": [
      "complete_checkout requires write semantics and a UUID checkout operation in PortContext.causation_id",
      "the adapter hashes immutable checkout facts and the complete request, adopts or binds one order-owner identity, and resumes pending or already placed orders",
      "payment collection and shipping option facts are retained in the typed identity projection",
      "read_checkout_result resolves by cart and read_checkout_result_by_operation resolves by checkout operation",
      "public storage and invariant errors use stable safe PortError messages"
    ]
  },
  "checkout_identity_provider_impl": {
    "service": "InProcessCheckoutOrderIdentityPort",
    "impl_type": "InProcessCheckoutOrderIdentityPort",
    "source": "crates/rustok-order/src/ports.rs",
    "status": "source_implemented_unvalidated",
    "notes": [
      "typed reads use order-owned order_checkout_identities persistence",
      "bind requires write idempotency and rejects conflicting operation/order/cart facts",
      "nullable cart, hash, payment, and shipping facts may be populated once and never replaced or cleared",
      "adopt_legacy keeps temporary metadata lookup inside the owner compatibility adapter",
      "commerce consumers no longer query orders or inspect checkout identity metadata directly"
    ]
  },
