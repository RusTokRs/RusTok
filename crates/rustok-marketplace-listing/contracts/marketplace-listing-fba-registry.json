{
  "schema_version": 1,
  "module": "marketplace_listing",
  "family": "marketplace",
  "role": "provider",
  "status": "in_progress",
  "contract_version": "marketplace.listing.v1",
  "ports": [
    {
      "name": "MarketplaceListingReadPort",
      "owner": "marketplace_listing",
      "operations": [
        "read_listing",
        "list_listings",
        "list_eligibility",
        "list_listing_events"
      ],
      "context": "rustok_api::ports::PortContext",
      "error": "rustok_api::ports::PortError",
      "idempotency_required": false,
      "deadline_required": true
    },
    {
      "name": "MarketplaceListingCommandPort",
      "owner": "marketplace_listing",
      "operations": [
        "create_listing",
        "update_listing_terms",
        "submit_listing_for_review",
        "review_listing",
        "publish_listing",
        "suspend_listing",
        "reactivate_listing",
        "archive_listing"
      ],
      "context": "rustok_api::ports::PortContext",
      "error": "rustok_api::ports::PortError",
      "idempotency_required": true,
      "deadline_required": true,
      "durable_receipt": {
        "table": "marketplace_listing_command_receipts",
        "identity_scope": [
          "tenant_id",
          "idempotency_key"
        ],
        "request_identity": "canonical_sha256_v1",
        "request_identity_includes": [
          "command_kind",
          "actor_id",
          "effective_locale",
          "normalized_request"
        ],
        "result_snapshot": "normalized_listing_response_json",
        "atomic_with_owner_write": true,
        "conflicting_payload": "marketplace_listing.idempotency_conflict",
        "provider_preflight_replay": [
          "create_listing",
          "publish_listing",
          "reactivate_listing"
        ]
      }
    }
  ],
  "dependencies": [
    {
      "module": "marketplace_seller",
      "port": "MarketplaceSellerReadPort",
      "usage": [
        "validate_seller_reference",
        "require_active_seller_for_publish",
        "require_active_seller_for_reactivate",
        "explain_eligibility"
      ],
      "foreign_entities_imported": false
    },
    {
      "module": "product",
      "port": "ProductCatalogReadPort",
      "usage": [
        "resolve_master_product_from_variant"
      ],
      "foreign_entities_imported": false
    }
  ],
  "consumers": [
    {
      "module": "marketplace",
      "profile": "marketplace_listing_directory",
      "degraded_modes": [
        "listing_directory_unavailable",
        "listing_eligibility_unavailable"
      ],
      "fallback_profiles": [
        "embedded_native",
        "remote_adapter_placeholder"
      ]
    }
  ],
  "ownership": {
    "aggregate_table": "marketplace_listings",
    "versioned_terms_table": "marketplace_listing_terms",
    "event_table": "marketplace_listing_events",
    "event_storage": {
      "append_only": true,
      "identity": "uuid",
      "scope": [
        "tenant_id",
        "listing_id"
      ],
      "audit_fields": [
        "actor_id",
        "event_kind",
        "locale",
        "note",
        "metadata",
        "created_at"
      ],
      "locale_source": "PortContext.locale_effective",
      "locale_normalizer": "rustok_api::normalize_locale_tag",
      "locale_max_bytes": 32,
      "timeline_order": [
        "created_at_desc",
        "id_desc"
      ],
      "atomic_commands": [
        "create_listing",
        "update_listing_terms",
        "submit_listing_for_review",
        "review_listing",
        "publish_listing",
        "suspend_listing",
        "reactivate_listing",
        "archive_listing"
      ],
      "event_kinds": [
        "created",
        "terms_updated",
        "submitted_for_review",
        "approved",
        "rejected",
        "published",
        "suspended",
        "reactivated",
        "archived"
      ],
      "compatibility_snapshots_still_present": [
        "approval_note",
        "suspension_reason"
      ],
      "planned_cutover": "backfill events then drop compatibility snapshot columns"
    },
    "one_scope_identity": [
      "tenant_id",
      "seller_id",
      "master_variant_id",
      "market_slug",
      "channel_slug"
    ],
    "canonical_product_content_copied": false,
    "localized_business_copy_owned": false,
    "localized_business_copy_provider": "rustok-product",
    "forbidden_listing_columns": [
      "title",
      "description",
      "localized_title",
      "localized_description",
      "translations_json",
      "localized_fields_json"
    ],
    "language_agnostic_fields": [
      "seller_sku",
      "market_slug",
      "channel_slug",
      "pricing_reference",
      "inventory_reference",
      "fulfillment_profile_slug"
    ],
    "cross_module_foreign_keys": false,
    "buy_box_ranking_owned": false,
    "direct_write_methods_in_service": false
  },
  "composition": {
    "module_manifest": "modules.toml",
    "distribution_feature": "mod-marketplace_listing",
    "server_feature": "mod-marketplace_listing",
    "default_enabled": false,
    "graphql_transport": "not_started",
    "ffa_package": "not_started"
  },
  "evidence": {
    "local_plan": "crates/rustok-marketplace-listing/docs/implementation-plan.md",
    "central_plan": "crates/rustok-commerce/docs/implementation-plan.md",
    "schema": "crates/rustok-marketplace-listing/src/migrations/m20260716_000001_create_marketplace_listings.rs",
    "event_schema": "crates/rustok-marketplace-listing/src/migrations/m20260717_000002_create_marketplace_listing_events.rs",
    "read_service": "crates/rustok-marketplace-listing/src/service.rs",
    "ports": "crates/rustok-marketplace-listing/src/ports.rs",
    "receipt_executor": "crates/rustok-marketplace-listing/src/command_receipts.rs",
    "provider_event_commands": "crates/rustok-marketplace-listing/src/replay_safe_commands.rs",
    "moderation_event_commands": "crates/rustok-marketplace-listing/src/evented_commands.rs",
    "owner_lifecycle_event_commands": "crates/rustok-marketplace-listing/src/lifecycle_event_commands.rs",
    "event_storage": "crates/rustok-marketplace-listing/src/listing_events.rs",
    "distribution_manifest": "crates/rustok-distribution/Cargo.toml",
    "distribution_registry": "crates/rustok-distribution/src/lib.rs",
    "server_manifest": "apps/server/Cargo.toml"
  },
  "contract_tests": {
    "status": "planned_cases_locked",
    "profiles": [
      "in_process",
      "remote_adapter_placeholder"
    ],
    "cases": [
      {
        "operation": "create_listing",
        "assertions": [
          "replay_checked_before_provider_reads",
          "seller_resolved_through_port",
          "variant_resolved_through_product_port",
          "seller_and_variant_scope_not_foreign_keyed",
          "canonical_product_localized_copy_not_persisted",
          "scope_identity_unique",
          "seller_sku_unique",
          "listing_terms_version_one_created_atomically",
          "created_event_and_receipt_atomic",
          "effective_locale_in_request_identity",
          "lost_response_replay_returns_saved_result",
          "conflicting_payload_rejected"
        ]
      },
      {
        "operation": "update_listing_terms",
        "assertions": [
          "new_terms_version_inserted",
          "previous_terms_retained",
          "listing_returns_to_draft_review",
          "terms_event_and_receipt_atomic",
          "effective_locale_in_request_identity"
        ]
      },
      {
        "operation": "submit_review_moderate_archive",
        "assertions": [
          "state_event_and_receipt_atomic",
          "event_actor_matches_port_actor",
          "effective_locale_in_request_identity",
          "lost_response_replay_returns_saved_result"
        ]
      },
      {
        "operation": "publish_listing",
        "assertions": [
          "replay_checked_before_seller_read",
          "seller_must_be_active",
          "listing_must_be_approved",
          "pricing_reference_required",
          "inventory_reference_required",
          "published_event_and_receipt_atomic",
          "effective_locale_in_request_identity"
        ]
      },
      {
        "operation": "reactivate_listing",
        "assertions": [
          "replay_checked_before_seller_read",
          "seller_must_be_active",
          "listing_must_be_approved",
          "pricing_reference_required",
          "inventory_reference_required",
          "reactivated_event_and_receipt_atomic",
          "effective_locale_in_request_identity"
        ]
      },
      {
        "operation": "list_listing_events",
        "assertions": [
          "tenant_and_listing_scope_preserved",
          "bounded_limit",
          "newest_first_order",
          "typed_event_kind",
          "locale_and_actor_returned"
        ]
      },
      {
        "operation": "list_eligibility",
        "assertions": [
          "deterministic_order",
          "explicit_reason_codes",
          "seller_status_resolved_through_port",
          "no_buy_box_ranking"
        ]
      },
      {
        "operation": "multilingual_storage",
        "assertions": [
          "listing_base_has_no_product_title_or_description",
          "listing_terms_store_owner_references_not_localized_copy",
          "localized_json_maps_forbidden",
          "operator_notes_use_immutable_locale_tagged_events"
        ]
      }
    ],
    "known_gap": "compatibility snapshot backfill/drop, outbox publication, compiled migrations, contention/replay, remote-profile, GraphQL/native transport, and FFA evidence are not yet retained"
  }
}
